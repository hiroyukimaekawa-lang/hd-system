{
  "manifest_version": 3,
  "name": "Google Maps Scraper v3",
  "version": "3.1.0",
  "description": "Googleマップから店舗情報を抽出してCSV/XLSXでダウンロードする拡張機能（v3.1: 接続エラー修正・高速化）",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "downloads",
    "power",
    "alarms",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.google.co.jp/maps/*"
  ],
  "action": {
    "default_popup": "popup-v3.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker-v3.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.co.jp/maps/*",
        "https://www.google.com/maps/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "config/areas.json",
        "config/genres.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}